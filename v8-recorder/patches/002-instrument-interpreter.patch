+#include "src/recorder/recorder.h"

 namespace v8 {
 namespace internal {
@@ -150,6 +151,28 @@ void Interpreter::DoDispatch(InterpreterAssembler* assembler) {
   Node* bytecode = assembler->BytecodeOperand(0);
   Node* target_bytecode = assembler->LoadBytecode(bytecode);

+  // 插桩：记录执行点
+  if (internal::Recorder::GetInstance()->IsRecording()) {
+    // 获取当前字节码偏移
+    Node* bytecode_offset = assembler->BytecodeOffset();
+
+    // 获取当前函数信息
+    Node* function = assembler->LoadRegister(Register::function_closure());
+    Node* shared_info = assembler->LoadObjectField(
+        function, JSFunction::kSharedFunctionInfoOffset);
+
+    // 获取行号和列号
+    Node* line_number = assembler->LoadObjectField(
+        shared_info, SharedFunctionInfo::kStartPositionOffset);
+
+    // 调用录制器
+    assembler->CallRuntime(
+        Runtime::kRecorderRecordExecutionPoint,
+        assembler->GetContext(),
+        bytecode_offset,
+        function);
+  }
+
   assembler->DispatchToBytecode(target_bytecode, bytecode_offset);
 }


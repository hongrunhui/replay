diff --git a/src/runtime/runtime-recorder.cc b/src/runtime/runtime-recorder.cc
new file mode 100644
index 0000000..1234567
--- /dev/null
+++ b/src/runtime/runtime-recorder.cc
@@ -0,0 +1,50 @@
+// Copyright 2024 V8 Recorder Project
+
+#include "src/runtime/runtime-utils.h"
+#include "src/recorder/recorder.h"
+#include "src/objects/js-function-inl.h"
+#include "src/objects/shared-function-info-inl.h"
+
+namespace v8 {
+namespace internal {
+
+RUNTIME_FUNCTION(Runtime_RecorderRecordExecutionPoint) {
+  HandleScope scope(isolate);
+  DCHECK_EQ(2, args.length());
+
+  int bytecode_offset = args.smi_value_at(0);
+  Handle<JSFunction> function = args.at<JSFunction>(1);
+
+  // 获取函数信息
+  Handle<SharedFunctionInfo> shared(function->shared(), isolate);
+  Handle<String> name = SharedFunctionInfo::DebugName(shared);
+
+  // 获取源码位置
+  int line_number = 0;
+  int column_number = 0;
+
+  if (shared->HasSourceCode()) {
+    Handle<Script> script(Script::cast(shared->script()), isolate);
+    Script::PositionInfo info;
+    Script::GetPositionInfo(script, shared->StartPosition(), &info);
+    line_number = info.line;
+    column_number = info.column;
+  }
+
+  // 获取调用栈深度
+  JavaScriptFrameIterator it(isolate);
+  uint32_t stack_depth = 0;
+  while (!it.done()) {
+    stack_depth++;
+    it.Advance();
+  }
+
+  // 记录执行点
+  Recorder::GetInstance()->RecordExecutionPoint(
+      bytecode_offset,
+      name->ToCString().get(),
+      line_number,
+      column_number,
+      stack_depth);
+
+  return ReadOnlyRoots(isolate).undefined_value();
+}
+
+} // namespace internal
+} // namespace v8

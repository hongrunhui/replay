@@ -30,6 +31,16 @@ BUILTIN(ConsoleLog) {
     }
   }

+  // 录制 console.log 输出
+  if (Recorder::GetInstance()->IsRecording()) {
+    std::string output;
+    for (int i = 1; i < args.length(); i++) {
+      Handle<String> str = Object::ToString(isolate, args.at(i)).ToHandleChecked();
+      output += str->ToCString().get();
+      if (i < args.length() - 1) output += " ";
+    }
+    Recorder::GetInstance()->RecordIO("console.log", output.c_str(), output.length());
+  }
+
   return ReadOnlyRoots(isolate).undefined_value();

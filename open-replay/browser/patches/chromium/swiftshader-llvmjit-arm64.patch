+// [open-replay browser patch 2026-04-28] __sincosf_stret 是 macOS x86 私有
+// 符号；arm64 SDK 14.2 已不导出。arm64 上 LLVM 把 sincos 拆成两次 sinf/cosf 调用，
+// 不会真用到 sincosf_stret，所以这里在 arm64 上注册 sincosf 占位兜底。
+#  if defined(__x86_64__) || defined(__i386__)
 			functions.try_emplace("__sincosf_stret", reinterpret_cast<void *>(__sincosf_stret));
+#  else
+			functions.try_emplace("sincosf", reinterpret_cast<void *>(sincosf));
+#  endif
 #elif defined(__linux__)
 			functions.try_emplace("sincosf", reinterpret_cast<void *>(sincosf));
 #elif defined(_WIN64)

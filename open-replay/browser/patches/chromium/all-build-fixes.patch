diff --git a/base/record_replay_inline.h b/base/record_replay_inline.h
index 6bd99fba3d6d5..e02665ee84d76 100644
--- a/base/record_replay_inline.h
+++ b/base/record_replay_inline.h
@@ -17,6 +17,45 @@ static void* LookupRecordReplaySymbol(const char* name) {
   return fnptr ? fnptr : reinterpret_cast<void*>(1);
 }
 
+// [open-replay browser patch 2026-04-27]
+// 补 partition_alloc 用到的 recordreplay::AutoDisallowEvents inline 版本。
+// Replay.io fork 在 base/record_replay.cc 提供完整的 C++ 命名空间实现，
+// 但 partition_alloc 子组件不链 record_replay.cc，又调用了 AutoDisallowEvents，
+// 引发 link error。这里以 dlsym(RTLD_DEFAULT, ...) 在运行期解析 driver 的
+// V8RecordReplayBeginDisallowEventsWithLabel / V8RecordReplayEndDisallowEvents。
+namespace recordreplay {
+
+struct AutoDisallowEvents {
+  void *fnEnd;
+  AutoDisallowEvents(const char* label = nullptr) {
+    void* fnBegin = LookupRecordReplaySymbol(
+        label ? "V8RecordReplayBeginDisallowEventsWithLabel"
+              : "V8RecordReplayBeginDisallowEvents");
+    fnEnd = LookupRecordReplaySymbol("V8RecordReplayEndDisallowEvents");
+    if (fnBegin != reinterpret_cast<void*>(1)) {
+      if (label) {
+        reinterpret_cast<void(*)(const char*)>(fnBegin)(label);
+      } else {
+        reinterpret_cast<void(*)()>(fnBegin)();
+      }
+    }
+  }
+  ~AutoDisallowEvents() {
+    if (fnEnd != reinterpret_cast<void*>(1)) {
+      reinterpret_cast<void(*)()>(fnEnd)();
+    }
+  }
+};
+
+inline bool IsRecordingOrReplaying(const char* feature = nullptr,
+                                    const char* subfeature = nullptr) {
+  void* fn = LookupRecordReplaySymbol("V8IsRecordingOrReplaying");
+  if (fn == reinterpret_cast<void*>(1)) return false;
+  return reinterpret_cast<bool(*)(const char*, const char*)>(fn)(feature, subfeature);
+}
+
+}  // namespace recordreplay
+
 struct RecordReplayAutoPassThroughEvents {
   void *fnBegin;
   void *fnEnd;
